#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

cmd="${1:-help}"
shift || true

case "$cmd" in
  boot)
    ./scripts/setup.sh
    ./scripts/validate.sh
    ./scripts/doctor.sh
    python3 scripts/env-validator.py
    ./scripts/smoke.sh
    ./scripts/sample-task.sh
    ./scripts/contract-demo.sh
    python3 -c "import runpy; from pathlib import Path; ns = runpy.run_path('scripts/contract_runner.py'); runner = ns['ContractRunner'](Path('.')); request = {'task': {'id': 'task-123', 'title': 'Summarize repo changes', 'priority': 'medium', 'requester': {'id': 'human', 'displayName': 'human'}, 'budget': {'maxCostUsd': 5, 'maxRuntimeMinutes': 15}, 'approval': {'required': False}, 'constraints': {'outputFormat': 'markdown', 'outputLength': 'short', 'allowNetwork': False}, 'routing': {'inbound': 'paperclip', 'outbound': 'hermes'}}}; assert runner.validate_request(request)['id'] == 'task-123'; print('test-contract ok')"
    ./scripts/template-selector.py repo-summary
    ./scripts/template-selector.py budget-check
    ! ./scripts/template-selector.py unknown-template
    ./scripts/task-runner.py
    ;;
  demo)
    "$0" boot
    ;;
  setup)
    ./scripts/setup.sh
    ;;
  validate)
    ./scripts/validate.sh
    ;;
  doctor)
    ./scripts/doctor.sh
    ;;
  runtime-check)
    python3 scripts/env-validator.py
    ;;
  smoke)
    ./scripts/smoke.sh
    ;;
  sample-task)
    ./scripts/sample-task.sh
    ;;
  sample-task-budget)
    ./scripts/sample-task.sh budget-check
    ;;
  task-run)
    ./scripts/task-runner.py
    ;;
  contract-demo)
    ./scripts/contract-demo.sh
    ;;
  test-contract)
    python3 -c "import runpy; from pathlib import Path; ns = runpy.run_path('scripts/contract_runner.py'); runner = ns['ContractRunner'](Path('.')); request = {'task': {'id': 'task-123', 'title': 'Summarize repo changes', 'priority': 'medium', 'requester': {'id': 'human', 'displayName': 'human'}, 'budget': {'maxCostUsd': 5, 'maxRuntimeMinutes': 15}, 'approval': {'required': False}, 'constraints': {'outputFormat': 'markdown', 'outputLength': 'short', 'allowNetwork': False}, 'routing': {'inbound': 'paperclip', 'outbound': 'hermes'}}}; assert runner.validate_request(request)['id'] == 'task-123'; print('test-contract ok')"
    ;;
  template-check)
    ./scripts/template-selector.py repo-summary
    ./scripts/template-selector.py budget-check
    ! ./scripts/template-selector.py unknown-template
    ;;
  help|*)
    cat <<'EOF'
Usage: scripts/agentopia <command>

Commands:
  boot
  demo
  setup
  validate
  doctor
  runtime-check
  smoke
  sample-task
  sample-task-budget
  task-run
  contract-demo
  test-contract
  template-check
EOF
    ;;
esac
