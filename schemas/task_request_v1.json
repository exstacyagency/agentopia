{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentopia.dev/schemas/task_request_v1.json",
  "title": "Agentopia Task Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task", "execution_policy", "routing", "trace"],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "task": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type", "title", "description", "priority", "risk_level", "requester", "created_at"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["repo_summary", "file_analysis", "text_generation", "structured_extract", "repo_change_plan", "implementation_draft"] },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
        "requester": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "display_name"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "display_name": { "type": "string", "minLength": 1 }
          }
        },
        "context": {
          "type": "object"
        },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "execution_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["budget", "approval", "permissions", "output_requirements"],
      "properties": {
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_cost_usd", "max_runtime_minutes"],
          "properties": {
            "max_cost_usd": { "type": "number", "minimum": 0 },
            "max_runtime_minutes": { "type": "integer", "minimum": 1 }
          }
        },
        "approval": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "status"],
          "properties": {
            "required": { "type": "boolean" },
            "status": { "type": "string", "enum": ["not_required", "pending", "approved", "rejected"] },
            "approved_by": { "type": "string" },
            "approved_at": { "type": "string", "format": "date-time" }
          }
        },
        "permissions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allow_network", "allow_memory", "allow_tools", "allowed_tool_classes", "write_scope"],
          "properties": {
            "allow_network": { "type": "boolean" },
            "allow_memory": { "type": "boolean" },
            "allow_tools": { "type": "boolean" },
            "allowed_tool_classes": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "write_scope": { "type": "string", "enum": ["none", "artifacts_only", "workspace_scoped"] }
          }
        },
        "output_requirements": {
          "type": "object",
          "additionalProperties": false,
          "required": ["format", "length", "include_artifacts"],
          "properties": {
            "format": { "type": "string", "enum": ["markdown", "json", "text"] },
            "length": { "type": "string", "enum": ["short", "medium", "long"] },
            "include_artifacts": { "type": "boolean" }
          }
        }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "destination", "callback"],
      "properties": {
        "source": { "type": "string", "const": "paperclip" },
        "destination": { "type": "string", "const": "hermes" },
        "callback": {
          "type": "object",
          "additionalProperties": false,
          "required": ["result_url", "auth_mode"],
          "properties": {
            "result_url": { "type": "string", "format": "uri" },
            "auth_mode": { "type": "string", "enum": ["shared_token"] }
          }
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "submitted_at"],
      "properties": {
        "trace_id": { "type": "string", "minLength": 1 },
        "submitted_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
